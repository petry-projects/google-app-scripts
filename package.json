{
  "name": "google-app-scripts",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test": "jest --runInBand",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check": "prettier --check . && npm run lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,ts,gs,json,md,yml,yaml}": "prettier --write",
    "**/*.{js,ts}": "eslint --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@types/google-apps-script": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
